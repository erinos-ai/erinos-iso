#!/usr/bin/env bash
set -euo pipefail

# Downloads the latest ErinOS ISO from GitHub Actions, flashes it to a USB drive,
# copies a .env config file, and optionally copies local Ollama models.
# Requires: gh (GitHub CLI), sgdisk (gptfdisk)

REPO="erinos-ai/erinos-iso"
ENV_PATH="/tmp/erinos-env"

# Usage: dev/flash [path/to/erinos.iso]
ISO_PATH="${1:-}"

# Locate .env.example: local checkout first, then fetch from GitHub
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_EXAMPLE=""
for candidate in "$SCRIPT_DIR/../../erinos-core/.env.example" "$HOME/code/erinos-ai/erinos-core/.env.example"; do
  if [[ -f "$candidate" ]]; then
    ENV_EXAMPLE="$candidate"
    break
  fi
done

if [[ -z "$ENV_EXAMPLE" ]]; then
  echo "Fetching .env.example from GitHub..."
  ENV_EXAMPLE="/tmp/erinos-env-example"
  gh api repos/erinos-ai/erinos-core/contents/.env.example --jq '.content' | base64 -d > "$ENV_EXAMPLE"
fi

# ── Get ISO ──────────────────────────────────────────────────────────
if [[ -n "$ISO_PATH" ]]; then
  if [[ ! -f "$ISO_PATH" ]]; then
    echo "ISO not found: ${ISO_PATH}"
    exit 1
  fi
  echo "Using local ISO: ${ISO_PATH}"
else
  ISO_PATH="/tmp/erinos.iso"
  echo "Fetching latest ISO from GitHub Actions..."

  RUN_ID=$(gh run list --repo "$REPO" --workflow build-iso.yml --status success --limit 1 --json databaseId --jq '.[0].databaseId')
  if [[ -z "$RUN_ID" ]]; then
    echo "No successful build found."
    exit 1
  fi

  ARTIFACT_NAME=$(gh api "repos/${REPO}/actions/runs/${RUN_ID}/artifacts" --jq '.artifacts[0].name')
  echo "Downloading artifact '${ARTIFACT_NAME}' from run #${RUN_ID}..."
  rm -rf /tmp/erinos-iso
  gh run download "$RUN_ID" --repo "$REPO" --name "$ARTIFACT_NAME" --dir /tmp/erinos-iso
  mv /tmp/erinos-iso/erinos.iso "$ISO_PATH"
  rm -rf /tmp/erinos-iso
  echo "Downloaded: ${ISO_PATH}"
fi

# ── Prepare .env ─────────────────────────────────────────────────────
cp "$ENV_EXAMPLE" "$ENV_PATH"

# Overlay values from local .env if present
LOCAL_ENV=""
for candidate in "$SCRIPT_DIR/../../erinos-core/.env" "$HOME/code/erinos-ai/erinos-core/.env"; do
  if [[ -f "$candidate" ]]; then
    LOCAL_ENV="$candidate"
    break
  fi
done

if [[ -n "$LOCAL_ENV" ]]; then
  while IFS='=' read -r key value; do
    [[ -z "$key" || "$key" == \#* ]] && continue
    if grep -q "^${key}=" "$ENV_PATH"; then
      sed -i '' "s|^${key}=.*|${key}=${value}|" "$ENV_PATH" 2>/dev/null || \
      sed -i "s|^${key}=.*|${key}=${value}|" "$ENV_PATH"
    elif grep -q "^# ${key}=" "$ENV_PATH"; then
      sed -i '' "s|^# ${key}=.*|${key}=${value}|" "$ENV_PATH" 2>/dev/null || \
      sed -i "s|^# ${key}=.*|${key}=${value}|" "$ENV_PATH"
    else
      echo "${key}=${value}" >> "$ENV_PATH"
    fi
  done < "$LOCAL_ENV"
fi

echo ""
echo "Opening configuration for editing..."
echo "Fill in your values, save, and close the editor."
"${EDITOR:-nano}" "$ENV_PATH"

# ── Select target disk ──────────────────────────────────────────────
echo ""
echo "Available disks:"
if [[ "$(uname)" == "Darwin" ]]; then
  diskutil list external physical
else
  lsblk -d -o NAME,SIZE,MODEL -n | grep -v "^loop\|^sr\|^ram"
fi

echo ""
read -rp "Target disk (e.g. disk4 or sdb): " DISK_NAME
DISK="/dev/${DISK_NAME}"

if [[ ! -b "$DISK" ]] && [[ ! -b "/dev/r${DISK_NAME}" ]]; then
  echo "Disk not found: ${DISK}"
  exit 1
fi

echo ""
echo "WARNING: This will ERASE ${DISK} and write the ErinOS installer ISO."
read -rp "Type YES to confirm: " CONFIRM
if [[ "$CONFIRM" != "YES" ]]; then
  rm -f "$ENV_PATH"
  echo "Aborted."
  exit 0
fi

# Pre-authenticate sudo
sudo true

# ── Flash ISO ────────────────────────────────────────────────────────
echo "Flashing ISO..."
if [[ "$(uname)" == "Darwin" ]]; then
  diskutil unmountDisk "$DISK"
  if command -v pv &>/dev/null; then
    pv "$ISO_PATH" | sudo dd of="/dev/r${DISK_NAME}" bs=4m 2>/dev/null
  else
    echo "(install pv for a progress bar: brew install pv)"
    sudo dd if="$ISO_PATH" of="/dev/r${DISK_NAME}" bs=4m 2>&1
  fi
else
  sudo umount "${DISK}"* 2>/dev/null || true
  if command -v pv &>/dev/null; then
    pv "$ISO_PATH" | sudo dd of="$DISK" bs=4M oflag=sync 2>/dev/null
  else
    sudo dd if="$ISO_PATH" of="$DISK" bs=4M status=progress oflag=sync
  fi
  sync
fi
echo "ISO written."
sleep 2

# ── Create data partition ────────────────────────────────────────────
echo "Creating data partition..."

if ! command -v sgdisk &>/dev/null; then
  echo "sgdisk not found. Install it:"
  echo "  macOS: brew install gptfdisk"
  echo "  Linux: pacman -S gptfdisk / apt install gdisk"
  exit 1
fi

# The ISO has 3 partitions (ISO9660, EFI, Gap1) and a backup GPT at the
# end of the image (~821MB), not the physical disk. In one pass:
# 1. Delete the Gap1 filler partition (3)
# 2. Move backup GPT to end of physical disk (-e)
# 3. Create a new partition 3 spanning the remaining space
sudo sgdisk -d 3 -e -n 3:0:0 -t 3:0700 -c 3:ERINOS "$DISK"

if [[ "$(uname)" == "Darwin" ]]; then
  sleep 1
  diskutil unmountDisk "$DISK" >/dev/null 2>&1 || true
  DATA_PART="/dev/${DISK_NAME}s3"
  sudo newfs_exfat -v ERINOS "$DATA_PART"
  diskutil mount "$DATA_PART" >/dev/null 2>&1
  DATA_MNT=$(diskutil info "$DATA_PART" | grep 'Mount Point' | sed 's/.*: *//')
else
  sudo partprobe "$DISK" 2>/dev/null || true
  sleep 1
  if [[ "$DISK" == *"nvme"* || "$DISK" == *"mmcblk"* ]]; then
    DATA_PART="${DISK}p3"
  else
    DATA_PART="${DISK}3"
  fi
  sudo mkfs.exfat -L ERINOS "$DATA_PART"
  DATA_MNT=$(mktemp -d)
  sudo mount "$DATA_PART" "$DATA_MNT"
fi

# ── Copy .env ────────────────────────────────────────────────────────
echo "Writing configuration..."
sudo mkdir -p "$DATA_MNT/erinos"
sudo cp "$ENV_PATH" "$DATA_MNT/erinos/.env"
rm -f "$ENV_PATH"
echo "Configuration written."

# ── Unmount and eject ────────────────────────────────────────────────
echo ""
if [[ "$(uname)" == "Darwin" ]]; then
  diskutil unmount "$DATA_PART" >/dev/null 2>&1 || true
  diskutil eject "$DISK"
else
  sudo umount "$DATA_MNT"
  rmdir "$DATA_MNT"
fi

echo "Done. USB drive is ready."
